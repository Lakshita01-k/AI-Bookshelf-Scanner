# Shelfie — Environment Variables
# Copy this file to backend/.env and adjust values as needed

# Set to true to use pre-baked demo scan data (no Tesseract/OCR required)
USE_DEMO_DATA=true

# SQLite database URL
DATABASE_URL=sqlite:///./app/data/shelfie.db

# Optional: Google Books API key (Open Library works without one)
GOOGLE_BOOKS_API_KEY=

# Path to Tesseract binary (only needed if USE_DEMO_DATA=false)
# Windows example: C:/Program Files/Tesseract-OCR/tesseract.exe
# macOS/Linux: tesseract
TESSERACT_CMD=tesseract
